{
	"name": "shuttle",
	"version": "0.1.0",
	"description": "Intelligent local → VPS deployment CLI",
	"type": "module",
	"bin": {
		"shuttle": "./src/index.ts"
	},
	"scripts": {
		"build": "bun run scripts/build.ts",
		"dev": "bun run src/index.ts",
		"test": "bun test",
		"test:integration": "SHUTTLE_INTEGRATION=1 bun test test/integration",
		"lint": "bunx biome check .",
		"lint:fix": "bunx biome check --write .",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"citty": "^0.1.6",
		"consola": "^3.4.0",
		"ora": "^8.2.0",
		"prompts": "^2.4.2",
		"ssh2": "^1.16.0",
		"yaml": "^2.7.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/prompts": "^2.4.9",
		"@types/ssh2": "^1.15.0",
		"bun-types": "latest"
	}
}
