---
import { docsNav } from "@/lib/nav";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === path || href === path + "/" || (href !== "/" && path.startsWith(href + "/"));
---
<nav aria-label="Docs navigation" class="space-y-7">
  {docsNav.map((section) => (
    <div>
      <p class="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        {section.title}
      </p>
      <ul class="space-y-px">
        {section.items.map((item) => {
          const active = isActive(item.href);
          return (
            <li>
              <a
                href={item.href}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "relative flex items-center rounded-md pl-4 pr-3 py-1.5 text-sm transition-colors",
                  active
                    ? "bg-primary/10 text-foreground font-medium before:absolute before:left-0 before:top-1.5 before:bottom-1.5 before:w-0.5 before:rounded-full before:bg-primary"
                    : "text-muted-foreground hover:text-foreground hover:bg-muted/60",
                ]}
              >
                {item.title}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</nav>
