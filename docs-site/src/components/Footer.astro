---
import { chrome, getLocale, localizePath } from "@/i18n";

const year = new Date().getFullYear();
const locale = getLocale(Astro.url.pathname);
const t = chrome[locale];
---
<footer class="mt-24 border-t border-border">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 grid gap-8 sm:grid-cols-3 text-sm">
    <div>
      <p class="font-semibold mb-3">DeployShuttle</p>
      <p class="text-muted-foreground">{t.tagline}</p>
    </div>
    <div>
      <p class="font-semibold mb-3">{t.resources}</p>
      <ul class="space-y-2 text-muted-foreground">
        <li><a href="/docs/quickstart" class="hover:text-foreground">{t.quickstart}</a></li>
        <li><a href="/docs/checks" class="hover:text-foreground">{t.checks}</a></li>
        <li><a href="/docs/github-action" class="hover:text-foreground">{t.action}</a></li>
      </ul>
    </div>
    <div>
      <p class="font-semibold mb-3">{t.project}</p>
      <ul class="space-y-2 text-muted-foreground">
        <li><a href="https://github.com/MakFly/deploy-shuttle" class="hover:text-foreground" target="_blank" rel="noreferrer">GitHub</a></li>
        <li><a href="https://github.com/MakFly/deploy-shuttle/releases" class="hover:text-foreground" target="_blank" rel="noreferrer">{t.releases}</a></li>
        <li><a href={localizePath("/pricing", locale)} class="hover:text-foreground">{t.pricing}</a></li>
        <li><a href={localizePath("/terms", locale)} class="hover:text-foreground">{t.terms}</a></li>
        <li><a href={localizePath("/legal", locale)} class="hover:text-foreground">{t.legal}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between text-xs text-muted-foreground">
      <span>© {year} MakFly. Open-core.</span>
      <span>Made with Astro & shadcn.</span>
    </div>
  </div>
</footer>
