---
import Root from "@/layouts/Root.astro";
import type { Locale } from "@/i18n";
import { localizePath } from "@/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const copy = {
  en: {
    title: "Thank you - DeployShuttle",
    h1: "Payment received. Welcome to Pro.",
    sub: "Your license key is on its way to your inbox — it usually arrives within a minute.",
    steps: [
      "Check your inbox (and the spam folder) for an email from DeployShuttle with your key.",
      "Activate it on your machine:",
      "That's it — HTML/PDF reports, harden --apply and the Pro templates are unlocked.",
    ],
    docsCta: "Read the license docs",
    supportNote: "Key not there after a few minutes? Reply to your Stripe receipt email and we'll sort it out.",
  },
  fr: {
    title: "Merci - DeployShuttle",
    h1: "Paiement reçu. Bienvenue dans Pro.",
    sub: "Votre clé de licence arrive dans votre boîte mail — généralement en moins d'une minute.",
    steps: [
      "Vérifiez votre boîte de réception (et les spams) : un email DeployShuttle contient votre clé.",
      "Activez-la sur votre machine :",
      "C'est tout — rapports HTML/PDF, harden --apply et templates Pro sont débloqués.",
    ],
    docsCta: "Lire la doc licence",
    supportNote: "Pas de clé après quelques minutes ? Répondez à l'email de reçu Stripe et on règle ça.",
  },
}[locale];

const docsHref = localizePath("/docs/commands/license", locale);
---
<Root title={copy.title} noindex>
  <section>
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full border-2 border-primary/60 text-primary">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h1 class="display display-section text-balance mt-6">{copy.h1}</h1>
      <p class="mt-4 text-muted-foreground">{copy.sub}</p>

      <ol class="mt-10 space-y-4 text-left text-sm">
        <li class="flex gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border text-xs font-medium">1</span>
          <span class="mt-0.5">{copy.steps[0]}</span>
        </li>
        <li class="flex gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border text-xs font-medium">2</span>
          <span class="mt-0.5 w-full">
            {copy.steps[1]}
            <pre class="mt-2 overflow-x-auto rounded-lg bg-foreground text-background px-4 py-3 font-mono text-xs sm:text-sm">shuttle license activate DS-XXXXXX-XXXXXX-XXXXXX</pre>
          </span>
        </li>
        <li class="flex gap-3">
          <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border text-xs font-medium">3</span>
          <span class="mt-0.5">{copy.steps[2]}</span>
        </li>
      </ol>

      <a href={docsHref} class="mt-10 inline-flex h-11 items-center justify-center rounded-full border border-border bg-background px-5 text-sm font-medium hover:bg-muted transition-colors">
        {copy.docsCta}
      </a>
      <p class="mt-6 text-xs text-muted-foreground">{copy.supportNote}</p>
    </div>
  </section>
</Root>
