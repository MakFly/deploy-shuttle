---
import { findAdjacent } from "@/lib/nav";
const { prev, next } = findAdjacent(Astro.url.pathname.replace(/\/$/, "") || "/");
---
{(prev || next) && (
  <nav class="mt-12 grid grid-cols-2 gap-4 border-t border-border pt-6 text-sm">
    <div>
      {prev && (
        <a href={prev.href} class="block rounded-md border border-border p-3 hover:bg-muted transition-colors">
          <span class="block text-xs text-muted-foreground">Previous</span>
          <span class="font-medium">{prev.title}</span>
        </a>
      )}
    </div>
    <div class="text-right">
      {next && (
        <a href={next.href} class="block rounded-md border border-border p-3 hover:bg-muted transition-colors">
          <span class="block text-xs text-muted-foreground">Next</span>
          <span class="font-medium">{next.title}</span>
        </a>
      )}
    </div>
  </nav>
)}
