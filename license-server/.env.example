# Postgres connection string (Neon / Supabase / self-hosted).
DATABASE_URL=postgres://user:password@host:5432/db?sslmode=require

# Ed25519 keypair used to sign and verify license tokens.
# Generate once with: bun run keygen
LICENSE_PRIVATE_KEY_B64=
LICENSE_PUBLIC_KEY_B64=

# Stripe (live or test mode).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_MONTHLY=price_...
STRIPE_PRO_PRICE_YEARLY=price_...

# Resend transactional email (leave empty in dev to log instead).
RESEND_API_KEY=
RESEND_FROM=DeployShuttle <noreply@deployshuttle.io>

# Token offline grace window (days). Default: 14.
TOKEN_GRACE_DAYS=14

PORT=3000
