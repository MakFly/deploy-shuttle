---
/**
 * Client-side syntax highlighting via Shiki + copy button.
 * Highlights all <pre><code class="language-*"> blocks on the page.
 */
---

<script>
  import { codeToHtml } from 'shiki'

  function isDark(): boolean {
    return document.documentElement.classList.contains('dark')
  }

  const LANG_MAP: Record<string, string> = {
    yaml: 'yaml',
    yml: 'yaml',
    bash: 'bash',
    sh: 'bash',
    shell: 'bash',
    json: 'json',
    typescript: 'typescript',
    ts: 'typescript',
    javascript: 'javascript',
    js: 'javascript',
    dockerfile: 'dockerfile',
    docker: 'dockerfile',
    php: 'php',
    text: 'text',
    plaintext: 'text',
    caddyfile: 'text',
    ini: 'ini',
  }

  function addCopyButton(pre: HTMLPreElement) {
    if (pre.querySelector('.copy-btn')) return

    const wrapper = document.createElement('div')
    wrapper.className = 'code-block-wrapper'
    pre.parentNode?.insertBefore(wrapper, pre)
    wrapper.appendChild(pre)

    const btn = document.createElement('button')
    btn.className = 'copy-btn'
    btn.setAttribute('aria-label', 'Copy code')
    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`

    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent || ''
      await navigator.clipboard.writeText(code)
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`
      btn.classList.add('copied')
      setTimeout(() => {
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`
        btn.classList.remove('copied')
      }, 2000)
    })

    wrapper.appendChild(btn)
  }

  async function highlightAll() {
    const dark = isDark()
    const theme = dark ? 'one-dark-pro' : 'one-light'
    const blocks = document.querySelectorAll('pre code[class*="language-"]')

    for (const block of blocks) {
      const pre = block.parentElement as HTMLPreElement | null
      if (!pre) continue

      // Store original code on first pass
      if (!pre.dataset.originalCode) {
        pre.dataset.originalCode = block.textContent || ''
        pre.dataset.originalLang = block.className.match(/language-(\w+)/)?.[1] || 'text'
      }

      const rawLang = pre.dataset.originalLang || 'text'
      const lang = LANG_MAP[rawLang] || 'text'
      const code = pre.dataset.originalCode || ''

      try {
        const html = await codeToHtml(code, { lang, theme })
        const temp = document.createElement('div')
        temp.innerHTML = html

        const shikiPre = temp.querySelector('pre')
        if (shikiPre) {
          const shikiCode = shikiPre.querySelector('code')
          if (shikiCode) {
            block.innerHTML = shikiCode.innerHTML
          }
          // Apply Shiki background
          pre.style.backgroundColor = shikiPre.style.backgroundColor || ''
          pre.dataset.highlighted = theme
        }
      } catch {
        pre.dataset.highlighted = 'fallback'
      }

      // Add copy button
      addCopyButton(pre)
    }
  }

  highlightAll()

  // Re-highlight on theme toggle
  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.attributeName === 'class') {
        highlightAll()
        break
      }
    }
  })
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] })
</script>
