---
import '../styles/global.css'
import { Header } from '@/components/docs/Header'
import CodeHighlight from '@/components/docs/CodeHighlight.astro'

interface Props {
  title?: string
}

const { title = 'Shuttle — Deploy Docker apps to any VPS' } = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Open-source Docker deployment CLI. Zero-downtime deploys, multi-server, secrets management. Think Kamal but pluggable." />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <Header client:load />
    <slot />
    <CodeHighlight />
  </body>
</html>
