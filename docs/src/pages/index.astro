---
import LandingLayout from '@/layouts/LandingLayout.astro'
---

<LandingLayout title="Shuttle — Deploy Docker apps to any VPS">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b">
    <div class="container mx-auto px-4 py-20 md:py-28 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs text-muted-foreground mb-6">
        Open-source &middot; MIT License &middot; TypeScript/Bun
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
        Deploy Docker apps to any VPS
      </h1>
      <p class="text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto mb-8">
        Open-source CLI for zero-downtime deployments. Blue-green, rolling, or Swarm.
        No platform lock-in.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/docs/getting-started"
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 transition-colors"
        >
          Get Started
        </a>
        <a
          href="https://github.com/shuttle-hq/shuttle"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-md border px-6 py-2.5 text-sm font-medium hover:bg-accent transition-colors gap-2"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="container mx-auto px-4 py-16 md:py-20">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">
      Everything you need to ship with confidence
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Zero-Downtime -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#9654;</div>
        <h3 class="font-semibold mb-1">Zero-Downtime Deploys</h3>
        <p class="text-sm text-muted-foreground">
          Blue-green deployments keep your old container running until the new one passes health checks. Instant rollback on failure.
        </p>
      </div>
      <!-- Multi-Server -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#127760;</div>
        <h3 class="font-semibold mb-1">Multi-Server</h3>
        <p class="text-sm text-muted-foreground">
          Deploy to multiple servers simultaneously. Rolling updates across a fleet with configurable concurrency and convergence checks.
        </p>
      </div>
      <!-- Secrets -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#128274;</div>
        <h3 class="font-semibold mb-1">Secrets Management</h3>
        <p class="text-sm text-muted-foreground">
          AES-256-GCM encrypted secrets stored alongside your config. Push to all servers with <code class="text-xs">shuttle secrets push</code>.
        </p>
      </div>
      <!-- Health Checks -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#10084;</div>
        <h3 class="font-semibold mb-1">Health Checks</h3>
        <p class="text-sm text-muted-foreground">
          Configurable HTTP health checks gate every deployment. Auto-rollback if the new container never becomes healthy.
        </p>
      </div>
      <!-- CI/CD -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#9881;</div>
        <h3 class="font-semibold mb-1">CI/CD Ready</h3>
        <p class="text-sm text-muted-foreground">
          First-class GitHub Actions and GitLab CI templates. <code class="text-xs">shuttle ci</code> generates the workflow file for your repo.
        </p>
      </div>
      <!-- Local Dev -->
      <div class="rounded-lg border bg-card p-6">
        <div class="mb-3 text-2xl">&#128187;</div>
        <h3 class="font-semibold mb-1">Local Dev Mode</h3>
        <p class="text-sm text-muted-foreground">
          Spin up a production-like environment on your laptop with <code class="text-xs">shuttle dev</code>. Caddy + mkcert for real HTTPS locally.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick example -->
  <section class="border-t">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold mb-4 text-center">
          One config file. That&rsquo;s it.
        </h2>
        <p class="text-muted-foreground text-center mb-8">
          Drop a <code class="text-sm">shuttle.yml</code> in your repo root. Shuttle handles the rest.
        </p>
        <div class="rounded-lg border bg-muted/30 overflow-hidden">
          <div class="flex items-center gap-2 px-4 py-2 border-b bg-muted/50">
            <span class="text-xs text-muted-foreground font-mono">shuttle.yml</span>
          </div>
          <pre class="p-4 text-sm overflow-x-auto"><code class="language-yaml">app: my-app
domain: my-app.example.com
server: deploy@203.0.113.10

build:
  context: .
  dockerfile: Dockerfile

deploy:
  strategy: blue-green
  timeout: 120
  retain: 5

services:
  web:
    port: 3000
    healthcheck:
      path: /up
      interval: 10s

accessories:
  postgres:
    preset: postgres
    env:
      POSTGRES_PASSWORD: !secret DB_PASSWORD

secrets:
  file: .shuttle.secrets

proxy:
  driver: caddy
  ssl: true</code></pre>
        </div>
        <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/docs/getting-started"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 transition-colors"
          >
            Follow the Quick Start
          </a>
          <a
            href="/docs/configuration"
            class="inline-flex items-center justify-center rounded-md border px-6 py-2.5 text-sm font-medium hover:bg-accent transition-colors"
          >
            Full Configuration Reference
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Compare -->
  <section class="border-t bg-muted/20">
    <div class="container mx-auto px-4 py-16 md:py-20">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-8">How Shuttle compares</h2>
      <div class="max-w-3xl mx-auto overflow-x-auto">
        <table class="w-full text-sm border rounded-lg overflow-hidden">
          <thead>
            <tr class="border-b bg-muted/50">
              <th class="text-left px-4 py-3 font-semibold">Feature</th>
              <th class="text-center px-4 py-3 font-semibold">Shuttle</th>
              <th class="text-center px-4 py-3 font-semibold">Kamal</th>
              <th class="text-center px-4 py-3 font-semibold">Dokku</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="px-4 py-3">Zero-downtime deploys</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#10003;</td>
            </tr>
            <tr class="border-b">
              <td class="px-4 py-3">Pluggable proxy (Caddy/Nginx/Traefik)</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
              <td class="text-center px-4 py-3">Nginx</td>
            </tr>
            <tr class="border-b">
              <td class="px-4 py-3">Docker Swarm support</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
            </tr>
            <tr class="border-b">
              <td class="px-4 py-3">Pluggable registry (GHCR, DockerHub, local)</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
            </tr>
            <tr class="border-b">
              <td class="px-4 py-3">Built-in secrets (AES-256-GCM)</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
            </tr>
            <tr>
              <td class="px-4 py-3">Local dev mode with SSL</td>
              <td class="text-center px-4 py-3">&#10003;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
              <td class="text-center px-4 py-3">&#8212;</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</LandingLayout>
